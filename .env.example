# Public — exposed to browser
NEXT_PUBLIC_SITE_URL=http://localhost:3001
# Reown (WalletConnect): https://cloud.reown.com → Project → Domains
# Local dev uses browser wallets only; for production add your Vercel URL to the allowlist.
NEXT_PUBLIC_WC_PROJECT_ID=replace_wallet_connect_key
NEXT_PUBLIC_MONAD_TESTNET_RPC=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_BASE_SEPOLIA_RPC=https://base-sepolia-rpc.publicnode.com

# Base Sepolia — native ETH odemeli kontrat (deploy sonrasi guncelle)
NEXT_PUBLIC_BASE_NFT_ADDRESS=0x0eB83A50981bDcB26C4b471ae4eCe2f87448A127

# Monad Testnet — WETH (ETH) odemeli kontrat (deploy sonrasi guncelle)
NEXT_PUBLIC_MONAD_NFT_ADDRESS=0xc79Eb92d332E7E719C579405b20fa2908D177b1B
NEXT_PUBLIC_MONAD_WETH_ADDRESS=0xEE8c0E9f1BFFb4Eb878d8f15f368A02a35481242

# Server only — never prefix with NEXT_PUBLIC_
DEPLOYER_PRIVATE_KEY=

# Opsiyonel — Base Sepolia faucet (ücretsiz): https://portal.cdp.coinbase.com
# CDP_API_KEY_ID=
# CDP_API_KEY_SECRET=
